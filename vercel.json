{
  "functions": {
    "api/*.py": {
      "runtime": "python3.12"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Telegram-Init-Data, X-Requested-With" }
      ]
    }
  ]
}
